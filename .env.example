# n8n Webhook node URL that receives survey submissions.
# Use the Production URL from your n8n Webhook node (not the Test URL).
# Example: https://your-n8n-instance.com/webhook/smart-cane-survey
VITE_N8N_WEBHOOK_URL=

# Optional: only set this if your n8n webhook is protected with Header Auth.
# It is sent as: Authorization: Bearer <value>
VITE_N8N_WEBHOOK_TOKEN=
